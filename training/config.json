{
  "architecture_version": "reasoner-v4",
  "built_in_curiosity_loop": true,
  "built_in_self_training": true,
  "built_in_skill_bank": true,
  "inference": {
    "cache_backend": "paged-kv",
    "curiosity_budget": 3,
    "curiosity_enabled": true,
    "kernel_reuse_enabled": true,
    "long_context_strategy": "compress-retrieve-route",
    "max_context_tokens": 196608,
    "max_new_tokens": 2048,
    "min_kernel_confidence": 0.25,
    "reasoning_passes": 4,
    "repetition_penalty": 1.08,
    "self_consistency_samples": 5,
    "system_prompt": "You are a careful, exact, high-agency reasoning assistant.",
    "temperature": 0.6,
    "top_k": 32,
    "top_p": 0.92,
    "verification_passes": 3
  },
  "memory_budget_tokens": 196608,
  "model_family": "decoder-only",
  "name": "KernelWeave-Reasoner",
  "notes": [
    "The compact frontier config is tuned for long context and reasoning depth, not only raw size.",
    "The system should earn its confidence through evidence, not vibes.",
    "Kernel reuse is built in and should stay active during both inference and training simulation."
  ],
  "safety_mode": "strict",
  "tokenizer": {
    "byte_fallback": true,
    "kind": "byte-bpe",
    "lowercase": false,
    "max_merge_rounds": 12000,
    "min_pair_frequency": 2,
    "special_tokens": [
      "<pad>",
      "<bos>",
      "<eos>",
      "<unk>"
    ],
    "vocab_size": 32768
  },
  "training": {
    "activation_checkpointing": true,
    "batch_size": 256,
    "checkpoint_every": 2000,
    "curiosity_fraction": 0.1,
    "curriculum_boundaries": [
      4096,
      8192,
      16384,
      32768,
      65536,
      131072
    ],
    "data_mix": {
      "code": 0.15,
      "dialogue": 0.1,
      "general_text": 0.25,
      "math": 0.15,
      "reasoning": 0.2,
      "skills": 0.05,
      "tool_traces": 0.1
    },
    "eval_every": 1000,
    "grad_clip": 1.0,
    "gradient_accumulation_steps": 2,
    "learning_rate": 0.0002,
    "log_every": 10,
    "max_steps": 500000,
    "micro_batch_size": 8,
    "optimizer": "adamw",
    "optimizer_betas": [
      0.9,
      0.95
    ],
    "packed_sequences": true,
    "precision": "bf16",
    "reasoning_trace_fraction": 0.25,
    "rerank_fraction": 0.05,
    "seed": 42,
    "self_play_fraction": 0.1,
    "sequence_length": 32768,
    "synthetic_fraction": 0.1,
    "trace_distillation_fraction": 0.25,
    "warmup_steps": 4000,
    "weight_decay": 0.1
  },
  "transformer": {
    "activation": "silu",
    "context_length": 196608,
    "curvature_memory_depth": 8,
    "d_ff": 8192,
    "d_model": 2048,
    "dropout": 0.0,
    "expert_ffn_multiplier": 1.0,
    "kernel_routing_enabled": true,
    "n_experts": 8,
    "n_heads": 16,
    "n_kv_heads": 4,
    "n_layers": 24,
    "norm_eps": 1e-05,
    "reasoning_router": "hybrid",
    "rope_theta": 800000.0,
    "router_hidden_dim": 384,
    "tie_embeddings": true,
    "top_k_experts": 2,
    "use_flash_attention": true,
    "use_gqa": true,
    "use_moe": true,
    "use_rmsnorm": true
  }
}